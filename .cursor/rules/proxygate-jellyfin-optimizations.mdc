## Implementation in ProxyGate

### app presets system (src/lib/appPresets.ts)

ProxyGate should ship with pre-configured optimization presets for known apps.
When a user selects "Jellyfin" as the app type when creating a service group,
the preset is automatically applied to the generated Traefik config.

```typescript
// src/lib/appPresets.ts

export type AppPreset = 'jellyfin' | 'plex' | 'generic' | 'api' | 'static'

export interface PresetConfig {
  flushInterval: string
  readTimeout: string
  writeTimeout: string
  idleTimeout: string
  maxIdleConnsPerHost: number
  excludeGzipMimeTypes: string[]
  requiredRequestHeaders: Record<string, string>
  websocketSupport: boolean
  tlsMinVersion: string
  noBodySizeLimit: boolean
  healthCheckPath: string
}

export const APP_PRESETS: Record<AppPreset, PresetConfig> = {

  jellyfin: {
    flushInterval: '0ms',               // stream immediately, no buffering
    readTimeout: '6h',                  // long streams
    writeTimeout: '6h',
    idleTimeout: '90s',
    maxIdleConnsPerHost: 200,
    excludeGzipMimeTypes: [
      'video/mp4', 'video/webm', 'video/x-matroska', 'video/mpeg', 'video/ogg',
      'audio/mpeg', 'audio/mp4', 'audio/ogg', 'audio/flac', 'audio/aac',
      'image/jpeg', 'image/png', 'image/webp', 'image/gif',
      'application/octet-stream',
    ],
    requiredRequestHeaders: {
      'X-Forwarded-Proto': 'https',
    },
    websocketSupport: true,
    tlsMinVersion: 'VersionTLS13',
    noBodySizeLimit: true,
    healthCheckPath: '/health',
  },

  plex: {
    flushInterval: '0ms',               // same as jellyfin — streaming
    readTimeout: '6h',
    writeTimeout: '6h',
    idleTimeout: '90s',
    maxIdleConnsPerHost: 200,
    excludeGzipMimeTypes: [
      'video/mp4', 'video/webm', 'audio/mpeg', 'audio/mp4',
      'image/jpeg', 'image/png', 'application/octet-stream',
    ],
    requiredRequestHeaders: {
      'X-Forwarded-Proto': 'https',
      'X-Plex-Protocol': '1.0',
    },
    websocketSupport: true,
    tlsMinVersion: 'VersionTLS13',
    noBodySizeLimit: true,
    healthCheckPath: '/identity',       // Plex uses /identity not /health
  },

  api: {
    flushInterval: '100ms',             // APIs benefit from slight buffering for small responses
    readTimeout: '30s',
    writeTimeout: '30s',
    idleTimeout: '60s',
    maxIdleConnsPerHost: 100,
    excludeGzipMimeTypes: [],           // compress everything for APIs
    requiredRequestHeaders: {},
    websocketSupport: false,
    tlsMinVersion: 'VersionTLS12',
    noBodySizeLimit: false,
    healthCheckPath: '/health',
  },

  static: {
    flushInterval: '100ms',
    readTimeout: '30s',
    writeTimeout: '30s',
    idleTimeout: '60s',
    maxIdleConnsPerHost: 50,
    excludeGzipMimeTypes: [
      'image/jpeg', 'image/png', 'image/webp', 'image/gif', 'image/ico',
      'font/woff', 'font/woff2',
    ],
    requiredRequestHeaders: {},
    websocketSupport: false,
    tlsMinVersion: 'VersionTLS12',
    noBodySizeLimit: false,
    healthCheckPath: '/',
  },

  generic: {
    flushInterval: '100ms',
    readTimeout: '60s',
    writeTimeout: '60s',
    idleTimeout: '60s',
    maxIdleConnsPerHost: 100,
    excludeGzipMimeTypes: [
      'image/jpeg', 'image/png', 'image/webp', 'application/octet-stream',
    ],
    requiredRequestHeaders: {},
    websocketSupport: false,
    tlsMinVersion: 'VersionTLS12',
    noBodySizeLimit: false,
    healthCheckPath: '/',
  },
}
```

### Integration in configGen.ts

```typescript
// In buildTraefikV3YAML(), when generating a service group:

import { APP_PRESETS, AppPreset } from './appPresets'

function buildServiceConfig(group: ServiceGroup): string {
  const preset = APP_PRESETS[group.appPreset ?? 'generic']

  return `
  serversTransports:
    ${group.id}-transport:
      respondingTimeouts:
        readTimeout:  "${preset.readTimeout}"
        writeTimeout: "${preset.writeTimeout}"
        idleTimeout:  "${preset.idleTimeout}"
      forwardingTimeouts:
        dialTimeout:            "10s"
        responseHeaderTimeout:  "30s"
        idleConnTimeout:        "${preset.idleTimeout}"
      maxIdleConnsPerHost: ${preset.maxIdleConnsPerHost}

  services:
    ${group.id}:
      loadBalancer:
        servers: ${group.upstreams.filter(u => u.status !== 'down')
          .map(u => `\n          - url: "http://${u.address}"`).join('')}
        responseForwarding:
          flushInterval: "${preset.flushInterval}"
        passHostHeader: true
        serversTransport: ${group.id}-transport
        healthCheck:
          path: "${group.healthCheckPath ?? preset.healthCheckPath}"
          interval: "${group.healthCheckInterval}"
          timeout: "${group.healthCheckTimeout}"
  `
}
```

