## 7. Data Models

interface Route {
  id: string
  matchType: 'subdomain' | 'path'
  hostname: string              // e.g. "jellyfin.example.com"
  pathPrefix?: string           // e.g. "/api"  (path type only)
  stripPathPrefix: boolean
  serviceGroupId: string        // FK → ServiceGroup.id
  tls: 'acme' | 'manual' | 'none' | 'redirect'
  middleware: string[]          // e.g. ["rate-limit","gzip"]
  enabled: boolean
  createdAt: string
}

interface ServiceGroup {
  id: string
  name: string                  // e.g. "jellyfin" "plex" "api"
  colour: string                // hex for dot in routes table
  loadBalancer: 'round-robin' | 'least-conn' | 'ip-hash' | 'weighted'
  healthCheckPath: string       // e.g. "/health"
  healthCheckInterval: string   // e.g. "30s"
  healthCheckTimeout: string    // e.g. "5s"
  passiveHealthCheck: boolean
  upstreams: Upstream[]
  createdAt: string
}

interface Upstream {
  id: string
  serviceGroupId: string
  address: string               // "192.168.1.10:8096"
  weight: number                // 1-10 default 1
  status: 'up' | 'down' | 'unknown'
  latencyMs?: number
  lastChecked?: string
}

interface MiddlewareConfig {
  id: string                    // slug e.g. "rate-limit"
  enabled: boolean
  config: Record<string, unknown>
}

interface TLSConfig {
  mode: 'acme' | 'manual'
  acmeEmail?: string
  acmeChallengeType?: 'HTTP-01' | 'DNS-01' | 'TLS-ALPN-01'
  certs: CertEntry[]
}

interface CertEntry {
  id: string
  domain: string
  certPath: string
  keyPath: string
  issuer: string
  expiresAt: string
  status: 'valid' | 'expiring' | 'expired'
}

interface AppSettings {
  publicIp: string
  httpPort: number
  httpsPort: number
  adminPort: number
  logLevel: 'DEBUG' | 'INFO' | 'WARN' | 'ERROR'
  configOutputPath: string
  cloudflareProxyEnabled: boolean
  haEnabled: boolean
  haRole: 'primary' | 'secondary'
  haVip: string
  haPeerIp: string
  haInterface: string
}

